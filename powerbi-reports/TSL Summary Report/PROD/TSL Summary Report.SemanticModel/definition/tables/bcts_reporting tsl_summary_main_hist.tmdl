	column 'FYTD Period Info' = ```
			
			"Data shown reflects period from " & 
			FORMAT(MIN('bcts_reporting tsl_summary_main_hist'[report_start_date]), "MMMM DD, YYYY") & 
			" to " & 
			FORMAT(MAX('bcts_reporting tsl_summary_main_hist'[report_end_date]), "MMMM DD, YYYY")
			& " (Data refreshed on "
			    & FORMAT(
			        MAX('bcts_reporting tsl_summary_main_hist'[report_run_timestamp]),
			        "MMMM dd, yyyy hh:mm AM/PM"
			      )
			    & ")"
			
			```
		lineageTag: d975ede0-611c-48dd-ac03-0d7869ae43b9
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

