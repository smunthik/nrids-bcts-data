table 'bcts_reporting licence_issued_ra_apportionment'
	lineageTag: 3307b4ae-44f5-4198-971d-6717818e8dee

	measure 'Actual FTE Count (paid absence incl.)' = ```
			
			VAR CurrentFY =
			    [Current FY Start Year] - 1
			RETURN
			CALCULATE (
			    SUM ( 'bcts_reporting licence_issued_ra_apportionment'[actual_fte_count] ),
			    'bcts_reporting licence_issued_ra_apportionment'[FY Start Year] <= CurrentFY
			)
			
			```
		lineageTag: f2718727-2c3b-4dfa-a0d8-2a23dfdbbc80

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Licence Issued (No Future)' = ```
			
			VAR CurrentFY =
			    [Current FY Start Year] - 1
			RETURN
			CALCULATE (
			    SUM('bcts_reporting licence_issued_ra_apportionment'[licence_issued]),
			    'bcts_reporting licence_issued_ra_apportionment'[FY Start Year] <= CurrentFY
			)
			
			```
		lineageTag: 20fe77a6-ab88-47c6-8db2-566894c85782

		annotation PBI_FormatHint = {"isGeneralNumber":true}

