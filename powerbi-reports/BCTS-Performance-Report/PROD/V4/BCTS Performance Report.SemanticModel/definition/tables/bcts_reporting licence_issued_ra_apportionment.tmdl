	measure 'Current FY Start Year' = ```
			
			VAR TodayDate = TODAY()
			VAR YearNum = YEAR(TodayDate)
			VAR MonthNum = MONTH(TodayDate)
			RETURN
			IF (
			    MonthNum >= 4,
			    YearNum,
			    YearNum - 1
			)
			
			```
		formatString: 0
		lineageTag: 2f4eaec9-f975-4656-94c6-e11754b9bfb7

